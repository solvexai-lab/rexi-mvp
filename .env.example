# REXI Environment Configuration
# Copy this file to .env and fill in your values

# ── Database ──
# Use local PostgreSQL (Docker) or cloud (Neon, Supabase, etc.)
DATABASE_URL=postgresql+asyncpg://rexi:rexi_pass@localhost:5432/reondb

# ── AI / LLM ──
# Gemini is required for contract analysis, plain English, chat
GEMINI_API_KEY=your-gemini-key-here
# OpenAI is optional (used by evaluation service if available)
OPENAI_API_KEY=

# ── Security ──
SECRET_KEY=change-this-to-a-random-string-in-production

# ── CORS (optional) ──
# Comma-separated list of origins for cross-domain access.
# Leave empty when serving frontend from same origin (default).
# CORS_ORIGINS=https://your-domain.com,https://app.your-domain.com

# ── Optional: Neo4j Knowledge Graph ──
# Leave empty to disable KG features (they degrade gracefully)
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=

# ── Optional: MinIO / S3 Storage ──
# Leave empty to use local disk uploads
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=

# ── Optional: Langfuse Observability ──
LANGFUSE_ENABLED=false
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
