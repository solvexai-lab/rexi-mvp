# REXI MVP Environment Variables

# PostgreSQL (Neon or local)
# Example Neon: postgresql+asyncpg://user:pass@host/db?sslmode=require
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/rexi_db

# Gemini API (required for AI features: Plain English, Chat, Explain Risk)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API (optional — used for clause extraction fallback and embeddings)
OPENAI_API_KEY=sk-your_openai_key_here

# App security
SECRET_KEY=change-this-to-a-random-string-in-production

# Neo4j (optional — GraphRAG features disable gracefully if missing)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=rexi_neo4j_2025

# File uploads
UPLOAD_DIR=./uploads

# MinIO / S3 (optional — falls back to local filesystem)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=rexi_minio
MINIO_SECRET_KEY=rexi_minio_secret
